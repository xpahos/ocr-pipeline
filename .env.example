# OpenAI
OPENAI_API_KEY=sk-...

# Vault root to watch (absolute path to your Obsidian vault or a subfolder)
OCR_VAULT_ROOT=/path/to/your/vault

# Vision-capable model used for handwriting recognition
OCR_MODEL=gpt-4o

# Optional proxy for all OpenAI traffic (e.g. a corporate SOCKS5 proxy).
# Use socks5h:// so DNS is resolved by the proxy. http(s):// also supported.
# Leave empty for a direct connection.
# OCR_PROXY=socks5h://user:pass@proxy.corp:1080

# Read timeout in seconds for OpenAI calls (streaming transcriptions can run long)
OCR_REQUEST_TIMEOUT=600

# Per-request limits (OpenAI: 100 pages / 32 MB). PDFs above these are auto-split.
OCR_MAX_PAGES=100
OCR_MAX_BYTES=33000000

# Seconds of quiet before a changed PDF is enqueued (debounces sync bursts)
OCR_DEBOUNCE_SECONDS=1.5

# Comma-separated glob patterns (relative to vault root) to ignore
OCR_IGNORE_GLOBS=.obsidian/**,.trash/**

# Logging
OCR_LOG_LEVEL=INFO

# Bounded retry on transient OpenAI errors (429/5xx)
OCR_MAX_RETRIES=3
